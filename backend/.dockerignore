# =============================================================================
# Docker 构建忽略文件
# =============================================================================

# Node.js 忽略项
node_modules
npm-debug.log
yarn-error.log
*.log
yarn.lock

# TypeScript 编译输出
dist
build
*.tsbuildinfo

# 开发文件
.git
.gitignore
.env
.env.*
!.env.example

# IDE 和编辑器配置
.vscode
.idea
*.swp
*.swo
.DS_Store

# 测试文件
coverage
.nyc_output
*.test.ts
*.spec.ts
__tests__

# 文档
README.md
docs
*.md

# Docker 相关文件 (避免循环引用)
docker-compose*.yml
Dockerfile*
.dockerignore

# 脚本文件 (仅构建时需要)
src/scripts

# 临时文件
tmp
temp
*.tmp
