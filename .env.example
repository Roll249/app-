# =============================================================================
# Personal Finance App - 环境变量配置模板
# 复制此文件为 .env 后根据实际情况修改配置
# =============================================================================

# ============================================================================
# PostgreSQL 数据库配置
# ============================================================================
POSTGRES_PASSWORD=postgres123

# PostgreSQL 映射端口 (默认 5432)
POSTGRES_PORT=5432

# ============================================================================
# 后端服务配置
# ============================================================================

# Node.js 环境 (development / production)
NODE_ENV=production

# 后端服务端口
BACKEND_PORT=3000

# JWT 密钥 (生产环境请使用足够长的随机字符串)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-64-characters

# CORS 允许的源 (多个用逗号分隔)
# 生产环境请修改为实际的前端域名
CORS_ORIGIN=http://localhost:3000,http://10.0.2.2:3000

# API 限流配置
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# 可选: pgAdmin 配置 (仅在 devtools profile 下启用)
# ============================================================================
PGADMIN_EMAIL=admin@fintech.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
