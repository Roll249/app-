# =============================================================================
# Personal Finance App - Environment Variables Template
# Copy this file to .env and configure based on your setup
# =============================================================================

# ============================================================================
# PostgreSQL Database
# ============================================================================
POSTGRES_PASSWORD=postgres123
POSTGRES_PORT=5432

# ============================================================================
# Backend Server
# ============================================================================

# Node.js environment (development / production)
NODE_ENV=production

# Backend port
BACKEND_PORT=3000

# JWT Secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-64-characters

# CORS (multiple origins separated by comma)
CORS_ORIGIN=http://localhost:3000,http://10.0.2.2:3000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# AI Service (Ollama)
# ============================================================================

# Ollama server URL (default: localhost:11434)
# For remote server: https://research.neu.edu.vn/ollama
OLLAMA_URL=http://localhost:11434

# Default AI model
OLLAMA_MODEL=qwen3:8b

# ============================================================================
# Banking Service
# ============================================================================

# Banking API URL (for real integration)
BANKING_API_URL=https://api.vietqr.vn

# VietQR API key (for production)
VIETQR_API_KEY=your-vietqr-api-key

# ============================================================================
# Notification Service
# ============================================================================

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your-fcm-server-key

# Email service (SendGrid, Mailgun, etc.)
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@fintech.app

# SMS service (Twilio, VNPT, etc.)
SMS_API_KEY=your-sms-api-key
SMS_FROM=+1234567890

# ============================================================================
# Sync Service
# ============================================================================

# Sync provider: local, google_drive, icloud
SYNC_PROVIDER=local

# Auto sync configuration (in milliseconds)
AUTO_SYNC_ENABLED=false
AUTO_SYNC_INTERVAL=300000

# Google Drive credentials (for cloud sync)
GOOGLE_DRIVE_CREDENTIALS_PATH=./config/google-drive-credentials.json

# ============================================================================
# Market Service
# ============================================================================

# Market data cache duration (in seconds, default: 300)
MARKET_CACHE_DURATION=300

# Real market data API (optional - for production)
MARKET_API_URL=https://api.exchangerate-api.com
MARKET_API_KEY=your-market-api-key

# ============================================================================
# Investment Service
# ============================================================================

# Stock API for real-time prices (optional)
STOCK_API_URL=https://api.polygon.io
STOCK_API_KEY=your-stock-api-key

# ============================================================================
# pgAdmin (optional - only enabled in devtools profile)
# ============================================================================
PGADMIN_EMAIL=admin@fintech.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
